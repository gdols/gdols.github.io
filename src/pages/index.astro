---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatDate } from "../utils";

const posts = (await getCollection("blog", (p) => !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const proyectos = (await getCollection("proyectos"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "gdols.dev",
      url: "https://gdols.dev/",
      inLanguage: "es",
    },
    {
      "@type": "Person",
      name: "Guille Dols",
      url: "https://gdols.dev/",
      email: "mailto:guille@gdols.dev",
      jobTitle: "Full stack developer",
      knowsAbout: [".NET", "Blazor", "SQL Server", "Azure", "Data Science", "Android", "APIs"],
      sameAs: [
        "https://github.com/gdols",
        "https://www.linkedin.com/in/guillermodols/",
      ],
    },
  ],
});
---
<Base>
  <script type="application/ld+json" is:inline set:html={jsonLd} />
  <div class="home-intro">
    <h1>Hola, soy Guille</h1>
    <p class="lead">
      Desarrollador full stack, principalmente con .NET, Blazor y SQL Server.
      También trabajo con Azure y estudio el Grado de Data Science.
    </p>
    <p>
      Esta web es donde voy dejando mis <a href="/proyectos/">proyectos</a> y
      <a href="/blog/">notas</a> de cosas que me han costado resolver o que no
      quiero volver a buscar. Si a alguien más le sirven, mejor.
    </p>
  </div>

  {proyectos.length > 0 && (
    <section class="home-section" aria-labelledby="proyectos-title">
      <h2 id="proyectos-title">Proyectos</h2>
      <ul class="list">
        {proyectos.map((proyecto) => (
          <li>
            <div class="row">
              {proyecto.data.page || proyecto.data.repo ? (
                <a href={proyecto.data.page ?? proyecto.data.repo}>{proyecto.data.title}</a>
              ) : (
                <strong>{proyecto.data.title}</strong>
              )}
              {proyecto.data.tech.length > 0 && (
                <span class="meta">{proyecto.data.tech.join(" · ")}</span>
              )}
            </div>
            <p>{proyecto.data.description}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {posts.length > 0 && (
    <section class="home-section" aria-labelledby="blog-title">
      <h2 id="blog-title">Lo último del blog</h2>
      <ul class="list">
        {posts.map((p) => (
          <li>
            <div class="row">
              <a href={`/blog/${p.id}/`}>{p.data.title}</a>
              <time datetime={p.data.date.toISOString()}>{formatDate(p.data.date)}</time>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>
