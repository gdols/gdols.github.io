---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatDate } from "../utils";

const posts = (await getCollection("blog", (p) => !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 1);

const proyectos = (await getCollection("proyectos"))
  .sort((a, b) => a.data.order - b.data.order);

const latestPost = posts[0];
const mdpipe = proyectos.find((p) => p.id === "mdpipe");
const apiverd = proyectos.find((p) => p.id === "apiverd");

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "gdols.dev",
      url: "https://gdols.dev/",
      inLanguage: "es",
    },
    {
      "@type": "Person",
      name: "Guille Dols",
      url: "https://gdols.dev/",
      email: "mailto:guille@gdols.dev",
      jobTitle: "Full stack developer",
      knowsAbout: [".NET", "Blazor", "SQL Server", "Azure", "Data Science", "Android", "APIs"],
      sameAs: [
        "https://github.com/gdols",
        "https://www.linkedin.com/in/guillermodols/",
      ],
    },
  ],
});
---
<Base>
  <script type="application/ld+json" is:inline set:html={jsonLd} />
  <div class="home">
    <div class="home-intro">
      <h1>Hola, soy Guille</h1>
      <p class="lead">
        Desarrollador full stack, principalmente con .NET, Blazor y SQL Server.
        También trabajo con Azure y estudio el Grado de Data Science.
      </p>
      <p>
        Esta web es donde voy dejando proyectos y notas de cosas que me ha
        costado resolver o que no quiero volver a buscar. Si a alguien más le
        sirven, mejor.
      </p>
    </div>

    {mdpipe && (
      <section class="home-current" aria-labelledby="current-title">
        <p class="home-label">Ahora mismo</p>
        <h2 id="current-title">
          <a href={mdpipe.data.repo}>{mdpipe.data.title}</a>
        </h2>
        <p>{mdpipe.data.description}</p>
        <p class="home-links">
          <a href="https://github.com/gdols/mdpipe/releases/latest/download/MdPipe.exe">Descargar</a>
          <a href={mdpipe.data.repo}>Ver el código</a>
          <a href="/proyectos/">Más proyectos</a>
        </p>

        {latestPost && (
          <div class="home-note">
            <p class="home-label">
              Última nota · <time datetime={latestPost.data.date.toISOString()}>{formatDate(latestPost.data.date)}</time>
            </p>
            <h3>
              <a href={`/blog/${latestPost.id}/`}>{latestPost.data.title}</a>
            </h3>
            {latestPost.data.summary && <p>{latestPost.data.summary}</p>}
          </div>
        )}
      </section>
    )}

    {apiverd && (
      <p class="home-more">
        También trabajo en <a href={apiverd.data.demo}>Apiverd</a>, donde pruebo
        aplicaciones Android, servicios API y productos pequeños.
      </p>
    )}
  </div>
</Base>
